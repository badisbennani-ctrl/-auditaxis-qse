# ========================================================
# AUDITAXIS QSE - CONFIGURATION BACKEND (EXEMPLE)
# ========================================================
# Recopiez ce fichier vers .env et complétez avec vos clés réelles.
# NE JAMAIS COMMITER LE FICHIER .env DANS LE DÉPÔT GIT.

# ========================================================
# 1. SERVEUR
# ========================================================
PORT=3001
NODE_ENV=production

# ========================================================
# 2. SÉCURITÉ & CORS
# ========================================================
# Origines autorisées (séparées par des virgules)
# Ex: https://auditaxis-qse.netlify.app,https://auditaxis-qse.com,http://localhost:3000
CORS_ORIGIN=https://auditaxis-qse.netlify.app,https://auditaxis-qse.com

# ========================================================
# 3. GOOGLE GEMINI (IA DIAGNOSTIC)
# ========================================================
# Obtenir sur : https://aistudio.google.com/apikey
GEMINI_API_KEY=votre_cle_api_ici

# ========================================================
# 4. RESEND (ENVOI D'EMAILS - CONTACT)
# ========================================================
# Obtenir sur : https://resend.com/api-keys
# ⚠️ SUR RENDER : Ajouter cette variable dans le Dashboard Render
#    → auditaxis-backend → Environment → Add Variable
RESEND_API_KEY=re_votre_cle_ici

# Email d'envoi (doit être vérifié sur Resend ou utiliser onboarding@resend.dev)
EMAIL_USER=noreply@votre-domaine.com

# Email de réception des messages de contact
EMAIL_TO=votre-email-de-reception@exemple.com
