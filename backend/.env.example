# ========================================================
# AUDITAXIS QSE - CONFIGURATION BACKEND (EXEMPLE)
# ========================================================
# Recopiez ce fichier vers .env et complétez avec vos clés réelles.
# NE JAMAIS COMMITER LE FICHIER .env DANS LE DÉPÔT GIT.

# ========================================================
# 1. SERVEUR
# ========================================================
PORT=3001
NODE_ENV=production

# ========================================================
# 2. SÉCURITÉ & CORS
# ========================================================
# Origines autorisées (séparées par des virgules)
CORS_ORIGIN=https://auditaxis-frontend-pied.vercel.app,https://auditaxis-qse.com

# ========================================================
# 3. GOOGLE GEMINI (IA DIAGNOSTIC)
# ========================================================
# Obtenir sur : https://aistudio.google.com/apikey
GEMINI_API_KEY=votre_cle_api_ici

# ========================================================
# 4. GMAIL SMTP (CONTACT)
# ========================================================
# Utiliser un App Password Gmail (pas votre mot de passe normal)
EMAIL_USER=badis.bennani@gmail.com
EMAIL_PASS=votre_app_password_gmail

# Email de réception des messages de contact
EMAIL_TO=votre-email-de-reception@exemple.com
