{
  "version": 2,
  "name": "auditaxis-frontend",
  "cleanUrls": true,
  "framework": null,
  "rewrites": [
    { "source": "/diagnostic", "destination": "/diagnostic.html" },
    { "source": "/checklist", "destination": "/checklist.html" },
    { "source": "/contact", "destination": "/contact.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/glossaire", "destination": "/glossaire.html" },
    { "source": "/expertise", "destination": "/expertise.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
